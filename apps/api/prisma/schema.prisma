generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  username  String
  message   String
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}
